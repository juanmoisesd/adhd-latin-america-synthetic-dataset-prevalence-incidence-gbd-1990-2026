{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "country": { "type": "string" },
    "year": { "type": "integer", "minimum": 1990, "maximum": 2026 },
    "prevalence_rate": { "type": "number" },
    "incidence_rate": { "type": "number" },
    "case_numbers": { "type": "integer" }
  },
  "required": ["country", "year", "prevalence_rate", "incidence_rate", "case_numbers"]
}
